---
// Components
import LanguageToggle from "../components/LanguageToggle.astro";
import ThemeToggle from "../components/ThemeToggle.astro";

// Assets
import { Image } from "astro:assets";
import logo from "../icons/logo.svg";

// Translations
import heroTranslations from "../locales/hero.locales.json";
const lang: "en" | "es" = Astro.currentLocale as "en" | "es";
const translations = heroTranslations[lang];
---

<>
  <menu>
    <ul
      id="header"
      class="header-menu fixed z-30 flex h-12 items-center gap-3 sm:h-14 sm:gap-4"
      tabindex="-1"
    >
      <li
        class="option header-surface header-shadow thin-border flex h-12 w-12 items-center justify-center rounded-full transition-all duration-1000 sm:h-14 sm:w-14"
      >
        <ThemeToggle />
      </li>
      <li
        class="option header-surface header-shadow thin-border flex h-12 w-12 items-center justify-center rounded-full transition-all duration-1000 sm:h-14 sm:w-14"
      >
        <LanguageToggle />
      </li>
      <li
        class="header-surface header-shadow thin-border z-30 h-full rounded-bl-full rounded-tl-full border-r-0 px-4 pr-7 sm:pr-8"
      >
        <div class="flex h-full items-center justify-center">
          <Image
            src={logo}
            alt={translations.logoAlt}
            loading="eager"
            class="w-10 sm:w-12"
          />
        </div>
      </li>
    </ul>
  </menu>

  <slot />
</>
<script src="../scripts/header.scripts.ts"></script>
