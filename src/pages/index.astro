---
// Components
import Loader from "../components/Loader.astro";
import Layout from "../layouts/Layout.astro";
import About from "../sections/About.astro";
import Footer from "../sections/Footer.astro";
import Hero from "../sections/Hero.astro";
import Projects from "../sections/Projects.astro";
import Contact from "../sections/Contact.astro";
import Skills from "../sections/Skills.astro";

const lang = (Astro.currentLocale ?? "en") as "en" | "es";
const siteUrl =
  Astro.site ?? new URL("https://valentin-nicheglod.is-a.dev");
const localePath = lang === "en" ? "/en" : "/es";
const canonicalUrl = new URL(localePath, siteUrl).toString();
const alternateEn = new URL("/en", siteUrl).toString();
const alternateEs = new URL("/es", siteUrl).toString();
const ogImageUrl = new URL("/og-image.jpg", siteUrl).toString();
const profileImageUrl = new URL("/profile-pic.png", siteUrl).toString();
const siteUrlString = siteUrl.toString();
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Valentín Nicheglod",
  alternateName: "Valentin Nicheglod",
  jobTitle: "Full Stack Developer & UI/UX Designer",
  url: canonicalUrl,
  image: profileImageUrl,
  description:
    "Full Stack Developer & UI/UX Designer from Uruguay. I build modern, fast and accessible digital products using Angular, React, Next.js, Astro and Firebase.",
  nationality: "Uruguayan",
  knowsLanguage: ["English", "Spanish"],
  sameAs: [
    "https://www.linkedin.com/in/valentin-nicheglod/",
    "https://github.com/ValentinNicheglod",
    "https://www.behance.net/valentin_nicheglod",
  ],
  worksFor: {
    "@type": "Organization",
    name: "Freelance / Vorello Agency",
  },
};
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Valentín Nicheglod Portfolio",
  url: siteUrlString,
  inLanguage: "en",
  potentialAction: {
    "@type": "SearchAction",
    target: "https://www.google.com/search?q=Valentín+Nicheglod+{search_term_string}",
    "query-input": "required name=search_term_string",
  },
  publisher: {
    "@type": "Person",
    name: "Valentín Nicheglod",
    url: canonicalUrl,
  },
};
---

<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <title>Valentín Nicheglod – Full Stack Developer & UI/UX Designer</title>
    <meta
      name="description"
      content="Portfolio of Valentín Nicheglod, full stack developer and UI/UX designer based in Uruguay. Explore my work, projects, skills and contact information."
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="mobile-web-app-capable" content="yes" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="es" href={alternateEs} />
    <link rel="alternate" hreflang="x-default" href={alternateEn} />
    <meta
      name="google-site-verification"
      content="uxdgTOSDIn_Rz8nYNcT7cyEe0I_jeQOpw5rsM9OtFFk"
    />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap"
      as="style"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap"
    />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta
      property="og:title"
      content="Valentín Nicheglod – Full Stack Developer & UI/UX Designer"
    />
    <meta
      property="og:description"
      content="Portfolio of Valentín Nicheglod, full stack developer and UI/UX designer based in Uruguay. Explore my projects, skills, and contact information."
    />
    <meta property="og:url" content={canonicalUrl} />
    <meta
      property="og:image"
      content={ogImageUrl}
    />
    <meta
      property="og:image:alt"
      content="Hero background with geometric lines and blue highlights."
    />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Valentín Nicheglod – Full Stack Developer & UI/UX Designer"
    />
    <meta
      name="twitter:description"
      content="Portfolio of Valentín Nicheglod, full stack developer and UI/UX designer based in Uruguay."
    />
    <meta
      name="twitter:image"
      content={ogImageUrl}
    />
    <meta
      name="twitter:image:alt"
      content="Hero background with geometric lines and blue highlights."
    />
    <script type="application/ld+json">
      {JSON.stringify(personSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(websiteSchema)}
    </script>
  </head>
  <body>
    <Layout>
      <div id="loader" class="absolute w-dvw h-dvh overflow-hidden theme-bg">
        <Loader />
      </div>
      <Hero />
      <main id="content">
        <About />
        <Skills />
        <Projects />
        <Contact />
        <Footer />
      </main>
    </Layout>
  </body>
  <style is:global>
    @import url(../styles/global.scss);
  </style>
  <script>
    import {
      initializeLanguage,
      showContent,
    } from "../scripts/initialization.scripts.ts";

    showContent();
    initializeLanguage();
  </script>
</html>
