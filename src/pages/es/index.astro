---
// Components
import Loader from "../../components/Loader.astro";
import Layout from "../../layouts/Layout.astro";
import About from "../../sections/About.astro";
import Footer from "../../sections/Footer.astro";
import Hero from "../../sections/Hero.astro";
import Projects from "../../sections/Projects.astro";
import Skills from "../../sections/Skills.astro";
import Contact from "../../sections/Contact.astro";
import "../../styles/global.scss";

const lang = (Astro.currentLocale ?? "en") as "en" | "es";
const siteUrl =
  Astro.site ?? new URL("https://valentin-nicheglod.is-a.dev");
const localePath = lang === "en" ? "/en" : "/es";
const canonicalUrl = new URL(localePath, siteUrl).toString();
const alternateEn = new URL("/en", siteUrl).toString();
const alternateEs = new URL("/es", siteUrl).toString();
const ogImageUrl = new URL("/og-image.jpg", siteUrl).toString();
const profileImageUrl = new URL("/profile-pic.png", siteUrl).toString();
const siteUrlString = siteUrl.toString();
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Valentín Nicheglod",
  alternateName: "Valentin Nicheglod",
  jobTitle: "Desarrollador Full Stack & Diseñador UI/UX",
  url: canonicalUrl,
  image: profileImageUrl,
  description:
    "Desarrollador Full Stack y diseñador UI/UX de Uruguay. Creo productos digitales modernos, rápidos y accesibles utilizando Angular, React, Next.js, Astro y Firebase.",
  nationality: "Uruguayo",
  knowsLanguage: ["Español", "Inglés"],
  sameAs: [
    "https://www.linkedin.com/in/valentin-nicheglod/",
    "https://github.com/ValentinNicheglod",
    "https://www.behance.net/valentin_nicheglod",
  ],
  worksFor: {
    "@type": "Organization",
    name: "Freelance / Vorello Agency",
  },
};
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Portafolio de Valentín Nicheglod",
  url: siteUrlString,
  inLanguage: "es",
  potentialAction: {
    "@type": "SearchAction",
    target: "https://www.google.com/search?q=Valentín+Nicheglod+{search_term_string}",
    "query-input": "required name=search_term_string",
  },
  publisher: {
    "@type": "Person",
    name: "Valentín Nicheglod",
    url: canonicalUrl,
  },
};
const showLoader = !import.meta.env.PROD;
---

<html lang="es" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <title>
      Valentín Nicheglod – Desarrollador Full Stack & Diseñador UI/UX
    </title>
    <meta
      name="description"
      content="Portafolio de Valentín Nicheglod, desarrollador full stack y diseñador UI/UX en Uruguay. Proyectos, experiencia y contacto."
    />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="mobile-web-app-capable" content="yes" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="es" href={alternateEs} />
    <link rel="alternate" hreflang="x-default" href={alternateEn} />
    <meta
      name="google-site-verification"
      content="uxdgTOSDIn_Rz8nYNcT7cyEe0I_jeQOpw5rsM9OtFFk"
    />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta
      property="og:title"
      content="Valentín Nicheglod – Desarrollador Full Stack & Diseñador UI/UX"
    />
    <meta
      property="og:description"
      content="Portafolio de Valentín Nicheglod, desarrollador full stack y diseñador UI/UX en Uruguay. Proyectos, habilidades y contacto."
    />
    <meta property="og:url" content={canonicalUrl} />
    <meta
      property="og:image"
      content={ogImageUrl}
    />
    <meta
      property="og:image:alt"
      content="Fondo abstracto con lineas geometricas y detalles azules."
    />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Valentín Nicheglod – Desarrollador Full Stack & Diseñador UI/UX"
    />
    <meta
      name="twitter:description"
      content="Portafolio de Valentín Nicheglod, desarrollador full stack y diseñador UI/UX en Uruguay."
    />
    <meta
      name="twitter:image"
      content={ogImageUrl}
    />
    <meta
      name="twitter:image:alt"
      content="Fondo abstracto con lineas geometricas y detalles azules."
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(personSchema)}
    ></script>
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(websiteSchema)}
    ></script>
  </head>
  <body>
    <Layout>
      {
        showLoader && (
          <div id="loader" class="absolute w-dvw h-dvh overflow-hidden">
            <Loader />
          </div>
        )
      }
      <Hero />
      <main id="content">
        <About />
        <Skills />
        <Projects />
        <Contact />
        <Footer />
      </main>
    </Layout>
  </body>
  <script>
    import { showContent } from "../../scripts/initialization.scripts.ts";

    showContent();
  </script>
</html>
